{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "A single financial transaction normalized from bank CSVs.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique fingerprint hash (date-desc-amount-bank)" },
        "date": { "type": "string", "description": "DD/MM/YYYY" },
        "description": { "type": "string", "description": "Merchant or description" },
        "amount": { "type": "number", "description": "Negative for spend, positive for income" },
        "category": { "type": "string", "description": "Spending category" },
        "bank": { "type": "string", "description": "Source bank name" },
        "uid": { "type": "string", "description": "Owner user ID" },
        "uploadLogIds": { "type": "array", "items": { "type": "string" }, "description": "IDs of upload logs containing this transaction" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When it was uploaded" }
      },
      "required": ["id", "date", "description", "amount", "category", "bank", "uid"]
    },
    "UploadLog": {
      "title": "UploadLog",
      "description": "A record of a CSV file upload event.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bank": { "type": "string" },
        "fileName": { "type": "string" },
        "transactionCount": { "type": "number" },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "periodStart": { "type": "string", "format": "date-time" },
        "periodEnd": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["id", "bank", "fileName", "transactionCount", "uploadedAt", "uid"]
    }
  },
  "firestore": {
    "users/{uid}/transactions": {
      "schema": "Transaction",
      "description": "User-specific transaction records"
    },
    "users/{uid}/upload_logs": {
      "schema": "UploadLog",
      "description": "History of uploaded CSV files"
    }
  }
}
